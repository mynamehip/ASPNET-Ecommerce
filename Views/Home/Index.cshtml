@model ASPNET_Ecommerce.Models.ViewModels.Home.HomeViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<ASPNET_Ecommerce.SharedResource> T

@{
    ViewData["Title"] = T["Nav.Home"];
    var sliderItems = Model.Settings.SliderItems.OrderBy(item => item.DisplayOrder).ThenBy(item => item.Id).ToList();
}

@if (Model.Settings.ShowHomepageSlider && sliderItems.Count > 0)
{
    <section class="mb-12">
        <div class="relative overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm" data-home-slider>
            @for (var index = 0; index < sliderItems.Count; index++)
            {
                var slide = sliderItems[index];
                var isBanner = slide.ItemType == ASPNET_Ecommerce.Models.Settings.SliderItemType.Banner;
                var activeClass = index == 0 ? "opacity-100 relative" : "opacity-0 absolute inset-0 pointer-events-none";
                var backgroundStyle = !string.IsNullOrWhiteSpace(slide.BackgroundImagePath)
                    ? $"background-image:url('{slide.BackgroundImagePath}')"
                    : "background-image:linear-gradient(135deg,#0f766e 0%,#115e59 45%,#111827 100%)";

                <div class="@activeClass transition-opacity duration-500" data-slider-item>
                    @if (isBanner)
                    {
                        <div class="relative min-h-[420px] sm:min-h-[500px] lg:min-h-[560px] bg-cover bg-center" style="@backgroundStyle">
                            <div class="absolute inset-0 bg-gradient-to-r from-gray-950/85 via-gray-900/65 to-gray-900/15"></div>
                            <div class="relative z-10 flex min-h-[420px] sm:min-h-[500px] lg:min-h-[560px] items-center px-8 py-14 sm:px-12 lg:px-16">
                                <div class="max-w-2xl text-white">
                                    @if (!string.IsNullOrWhiteSpace(slide.Content))
                                    {
                                        <span class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white/90">
                                            @slide.Content
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(slide.Title))
                                    {
                                        <h1 class="mt-5 text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl">@slide.Title</h1>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(slide.Description))
                                    {
                                        <p class="mt-5 max-w-xl text-sm leading-7 text-white/80 sm:text-base">@slide.Description</p>
                                    }
                                    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                                        @if (!string.IsNullOrWhiteSpace(slide.PrimaryButtonUrl))
                                        {
                                            <a href="@slide.PrimaryButtonUrl" class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition hover:bg-gray-100">
                                                Explore now
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(slide.SecondaryButtonUrl))
                                        {
                                            <a href="@slide.SecondaryButtonUrl" class="inline-flex items-center justify-center rounded-xl border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
                                                Learn more
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="@(slide.ClickUrl ?? "#")" class="relative block min-h-[420px] sm:min-h-[500px] lg:min-h-[560px] bg-gray-100">
                            @if (!string.IsNullOrWhiteSpace(slide.BackgroundImagePath))
                            {
                                <img src="@slide.BackgroundImagePath" alt="Homepage slide" class="absolute inset-0 h-full w-full object-cover" />
                            }
                            <div class="absolute inset-0 bg-gradient-to-t from-gray-950/45 via-gray-900/10 to-transparent"></div>
                        </a>
                    }
                </div>
            }

            @if (sliderItems.Count > 1)
            {
                <button type="button" class="absolute left-4 top-1/2 z-20 -translate-y-1/2 rounded-full border border-white/20 bg-gray-950/40 p-3 text-white backdrop-blur transition hover:bg-gray-950/60" data-slider-prev aria-label="Previous slide">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button type="button" class="absolute right-4 top-1/2 z-20 -translate-y-1/2 rounded-full border border-white/20 bg-gray-950/40 p-3 text-white backdrop-blur transition hover:bg-gray-950/60" data-slider-next aria-label="Next slide">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2 rounded-full border border-white/20 bg-gray-950/35 px-4 py-2 backdrop-blur">
                    @for (var index = 0; index < sliderItems.Count; index++)
                    {
                        <button type="button" class="h-2.5 w-2.5 rounded-full @(index == 0 ? "bg-white" : "bg-white/40") transition" data-slider-dot data-slider-index="@index" aria-label="Go to slide @(index + 1)"></button>
                    }
                </div>
            }
        </div>
    </section>
}

@if (Model.Settings.ShowHomepageCategories && Model.Categories.Count > 0)
{
    <section class="mb-12">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">@T["Home.ShopByCategory"]</h2>
                <p class="mt-1 text-sm text-gray-500">@T["Home.ShopByCategoryDescription"]</p>
            </div>
            <a asp-controller="Product" asp-action="Index" class="hidden items-center gap-1 text-sm font-medium text-brand-600 transition hover:text-brand-700 sm:inline-flex">
                @T["Action.ViewAll"]
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6">
            @foreach (var category in Model.Categories)
            {
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id" class="group flex flex-col items-center gap-3 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition hover:border-brand-200 hover:shadow-md">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 transition group-hover:bg-brand-100">
                        <svg class="h-6 w-6 text-brand-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    </div>
                    <div class="text-center">
                        <span class="text-sm font-semibold text-gray-900 transition group-hover:text-brand-700">@category.Name</span>
                        <span class="mt-0.5 block text-xs text-gray-400">@T["Home.CategoryProductCount", category.Products.Count]</span>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (Model.Settings.ShowHomepageNewProducts && Model.NewProducts.Count > 0)
{
    <section class="mb-12">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">New Products</h2>
                <p class="mt-1 text-sm text-gray-500">Fresh additions to the catalog, sorted from newest to oldest.</p>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            @foreach (var product in Model.NewProducts)
            {
                var primaryImage = product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault(i => i.IsPrimary) ?? product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault();
                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="group overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-shadow duration-300 hover:shadow-lg">
                    <div class="relative aspect-square overflow-hidden bg-gray-50">
                        @if (primaryImage is not null)
                        {
                            <img src="@primaryImage.ImagePath" alt="@product.Name" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                        }
                        else
                        {
                            <div class="flex h-full w-full items-center justify-center text-gray-300">
                                <svg class="h-16 w-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                        }
                        <span class="absolute left-3 top-3 rounded-full bg-gray-950 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em] text-white">New</span>
                    </div>
                    <div class="p-4">
                        <h3 class="line-clamp-2 text-sm font-semibold text-gray-900 transition group-hover:text-brand-700">@product.Name</h3>
                        <div class="mt-3">
                            @if (product.HasActiveDiscount)
                            {
                                <div class="text-lg font-bold text-brand-600">@product.EffectivePrice.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                                <div class="text-xs text-gray-400 line-through">@product.Price.ToString("N0") VND</div>
                            }
                            else
                            {
                                <div class="text-lg font-bold text-brand-600">@product.Price.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (Model.Settings.ShowHomepageFeaturedProducts && Model.FeaturedProducts.Count > 0)
{
    <section class="mb-12">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">@T["Home.FeaturedProducts"]</h2>
                <p class="mt-1 text-sm text-gray-500">@T["Home.FeaturedProductsDescription"]</p>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            @foreach (var product in Model.FeaturedProducts)
            {
                var primaryImage = product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault(i => i.IsPrimary) ?? product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault();
                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="group overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-shadow duration-300 hover:shadow-lg">
                    <div class="relative aspect-square overflow-hidden bg-gray-50">
                        @if (primaryImage is not null)
                        {
                            <img src="@primaryImage.ImagePath" alt="@product.Name" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                        }
                        else
                        {
                            <div class="flex h-full w-full items-center justify-center text-gray-300">
                                <svg class="h-16 w-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                        }
                        @if (product.Category is not null)
                        {
                            <span class="absolute left-3 top-3 rounded-full bg-white/90 px-2.5 py-1 text-[11px] font-semibold text-gray-700 shadow-sm backdrop-blur-sm">@product.Category.Name</span>
                        }
                    </div>
                    <div class="p-4">
                        <h3 class="line-clamp-2 text-sm font-semibold text-gray-900 transition group-hover:text-brand-700">@product.Name</h3>
                        <div class="mt-3">
                            @if (product.HasActiveDiscount)
                            {
                                <div class="text-lg font-bold text-brand-600">@product.EffectivePrice.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                                <div class="text-xs text-gray-400 line-through">@product.Price.ToString("N0") VND</div>
                            }
                            else
                            {
                                <div class="text-lg font-bold text-brand-600">@product.Price.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (Model.Settings.ShowHomepageDiscountProducts && Model.DiscountProducts.Count > 0)
{
    <section class="mb-12 rounded-[2rem] border border-amber-200 bg-gradient-to-br from-amber-50 via-orange-50 to-white p-8 shadow-sm">
        <div class="mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Discount Picks</h2>
            <p class="mt-1 text-sm text-gray-600">Products with direct per-item discounts managed from admin.</p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            @foreach (var product in Model.DiscountProducts)
            {
                var primaryImage = product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault(i => i.IsPrimary) ?? product.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault();
                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="group overflow-hidden rounded-2xl border border-amber-100 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
                    <div class="relative aspect-square overflow-hidden bg-gray-50">
                        @if (primaryImage is not null)
                        {
                            <img src="@primaryImage.ImagePath" alt="@product.Name" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                        }
                        else
                        {
                            <div class="flex h-full w-full items-center justify-center text-gray-300">
                                <svg class="h-16 w-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                        }
                        <span class="absolute right-3 top-3 rounded-full bg-rose-600 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em] text-white">
                            -@product.DiscountPercentage?.ToString("0.##")%
                        </span>
                    </div>
                    <div class="p-4">
                        <h3 class="line-clamp-2 text-sm font-semibold text-gray-900 transition group-hover:text-brand-700">@product.Name</h3>
                        <div class="mt-3">
                            <div class="text-lg font-bold text-brand-700">@product.EffectivePrice.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                            <div class="text-xs text-gray-400 line-through">@product.Price.ToString("N0") VND</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (Model.Settings.IsPromoBannerActive)
{
    <section class="mb-8 rounded-2xl bg-gray-900 px-8 py-12 text-center text-white sm:px-12">
        @if (!string.IsNullOrWhiteSpace(Model.Settings.PromoCode) || Model.Settings.PromoDiscountPercentage.HasValue)
        {
            <div class="mb-4 inline-flex flex-wrap items-center justify-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm font-medium">
                @if (!string.IsNullOrWhiteSpace(Model.Settings.PromoCode))
                {
                    <span>@T["Home.PromoCodeLabel"] <span class="font-bold text-white">@Model.Settings.PromoCode</span></span>
                }
                @if (Model.Settings.PromoDiscountPercentage.HasValue)
                {
                    <span class="text-brand-200">@T["Home.PromoDiscount", Model.Settings.PromoDiscountPercentage.Value.ToString("0.##")]</span>
                }
            </div>
        }
        <h2 class="mb-3 text-2xl font-bold sm:text-3xl">@Model.Settings.PromoTitle</h2>
        <p class="mx-auto mb-6 max-w-2xl text-sm text-gray-400 sm:text-base">@Model.Settings.PromoSubtitle</p>
        <a href="@Model.Settings.PromoButtonUrl" class="inline-flex rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-brand-700">
            @Model.Settings.PromoButtonText
        </a>
    </section>
}

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-home-slider]');
            if (!root) return;

            const items = Array.from(root.querySelectorAll('[data-slider-item]'));
            const dots = Array.from(root.querySelectorAll('[data-slider-dot]'));
            const prev = root.querySelector('[data-slider-prev]');
            const next = root.querySelector('[data-slider-next]');
            if (items.length <= 1) return;

            let currentIndex = 0;
            let timerId = null;

            function render(index) {
                currentIndex = (index + items.length) % items.length;
                items.forEach((item, itemIndex) => {
                    const active = itemIndex === currentIndex;
                    item.classList.toggle('opacity-100', active);
                    item.classList.toggle('relative', active);
                    item.classList.toggle('opacity-0', !active);
                    item.classList.toggle('absolute', !active);
                    item.classList.toggle('inset-0', !active);
                    item.classList.toggle('pointer-events-none', !active);
                });

                dots.forEach((dot, dotIndex) => {
                    dot.classList.toggle('bg-white', dotIndex === currentIndex);
                    dot.classList.toggle('bg-white/40', dotIndex !== currentIndex);
                });
            }

            function schedule() {
                if (timerId) window.clearInterval(timerId);
                timerId = window.setInterval(() => render(currentIndex + 1), 6000);
            }

            prev?.addEventListener('click', () => {
                render(currentIndex - 1);
                schedule();
            });

            next?.addEventListener('click', () => {
                render(currentIndex + 1);
                schedule();
            });

            dots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    render(index);
                    schedule();
                });
            });

            render(0);
            schedule();
        })();
    </script>
}
