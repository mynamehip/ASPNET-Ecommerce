@model ASPNET_Ecommerce.Models.ViewModels.Order.OrderConfirmationViewModel
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Order.Confirmation.Title"];

    var statusColor = Model.Status switch
    {
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Pending => "amber",
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Processing => "blue",
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Completed => "emerald",
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Cancelled => "red",
        _ => "gray"
    };

    var paymentColor = Model.PaymentStatus switch
    {
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Paid => "emerald",
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Authorized => "blue",
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Pending => "amber",
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Failed => "red",
        _ => "gray"
    };

    var statusText = Model.Status switch
    {
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Pending => T["Order.Status.Pending"].Value,
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Processing => T["Order.Status.Processing"].Value,
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Completed => T["Order.Status.Completed"].Value,
        ASPNET_Ecommerce.Models.Orders.OrderStatus.Cancelled => T["Order.Status.Cancelled"].Value,
        _ => Model.Status.ToString()
    };

    var paymentStatusText = Model.PaymentStatus switch
    {
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Pending => T["Order.PaymentStatus.Pending"].Value,
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Authorized => T["Order.PaymentStatus.Authorized"].Value,
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Paid => T["Order.PaymentStatus.Paid"].Value,
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Failed => T["Order.PaymentStatus.Failed"].Value,
        ASPNET_Ecommerce.Models.Orders.PaymentStatus.Refunded => T["Order.PaymentStatus.Refunded"].Value,
        _ => Model.PaymentStatus.ToString()
    };

    var paymentMethodText = Model.PaymentMethod switch
    {
        ASPNET_Ecommerce.Models.Orders.PaymentMethod.CashOnDelivery => T["Payment.CashOnDelivery"].Value,
        ASPNET_Ecommerce.Models.Orders.PaymentMethod.DemoGateway => T["Payment.DemoGateway"].Value,
        _ => Model.PaymentMethod.ToString()
    };
}

<div class="max-w-5xl mx-auto">

    <!-- Hero banner -->
    <div class="relative bg-gradient-to-br from-brand-600 via-brand-700 to-brand-800 rounded-3xl overflow-hidden shadow-xl mb-8">
        <div class="absolute inset-0 opacity-10">
            <svg class="w-full h-full" viewBox="0 0 800 400" fill="none"><circle cx="700" cy="50" r="280" fill="white"/><circle cx="100" cy="350" r="200" fill="white"/></svg>
        </div>
        <div class="relative px-6 sm:px-10 py-10 sm:py-14 text-center">
            <div class="mx-auto w-16 h-16 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center mb-5 ring-4 ring-white/10">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">@T["Order.Confirmation.HeroTitle"]</h1>
            <p class="mt-3 text-brand-100 text-sm sm:text-base max-w-lg mx-auto">@T["Order.Confirmation.HeroDescription", Model.OrderNumber]</p>
            <p class="mt-2 text-sm text-brand-100/90 max-w-xl mx-auto">@T["Order.Confirmation.HeroEmailHint"]</p>

            @if (TempData["OrderSuccess"] is string orderSuccess)
            {
                <div class="mt-5 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 backdrop-blur-sm text-white text-sm font-medium">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    @orderSuccess
                </div>
            }

            <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                <a asp-controller="Product" asp-action="Index"
                   class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-brand-700 bg-white rounded-xl hover:bg-brand-50 shadow-sm transition">
                    @T["Action.ContinueShopping"]
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
                <a asp-controller="Order" asp-action="Tracking" asp-route-id="@Model.OrderId"
                   class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-white/15 backdrop-blur-sm rounded-xl hover:bg-white/20 transition">
                    @T["Order.TrackOrder"]
                </a>
                <a asp-controller="Order" asp-action="Lookup" asp-route-orderNumber="@Model.OrderNumber"
                   class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-transparent border border-white/30 rounded-xl hover:bg-white/10 transition">
                    @T["Order.SaveLookupLater"]
                </a>
            </div>
        </div>
    </div>

    <!-- Order status strip -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-5 mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-@(statusColor)-50 flex items-center justify-center shrink-0">
                    @if (Model.Status == ASPNET_Ecommerce.Models.Orders.OrderStatus.Pending)
                    {
                        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    }
                    else if (Model.Status == ASPNET_Ecommerce.Models.Orders.OrderStatus.Processing)
                    {
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    }
                    else if (Model.Status == ASPNET_Ecommerce.Models.Orders.OrderStatus.Completed)
                    {
                        <svg class="w-5 h-5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    }
                </div>
                <div>
                    <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">@T["Order.OrderStatus"]</div>
                    <span class="inline-flex items-center gap-1.5 mt-0.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-@(statusColor)-100 text-@(statusColor)-800">
                        @statusText
                    </span>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
                <div>
                    <span class="text-gray-400">@T["Order.OrderNumberShort"]</span>
                    <span class="ml-1 font-mono font-semibold text-gray-900">@Model.OrderNumber</span>
                </div>
                <div class="hidden sm:block w-px h-4 bg-gray-200"></div>
                <div>
                    <span class="text-gray-400">@T["Label.Placed"]</span>
                    <span class="ml-1 font-semibold text-gray-900">@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                </div>
                <div class="hidden sm:block w-px h-4 bg-gray-200"></div>
                <div>
                    <span class="text-gray-400">@T["Label.Total"]</span>
                    <span class="ml-1 font-bold text-brand-600">@Model.TotalAmount.ToString("N0") @Model.CurrencyCode</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_340px] gap-6">

        <!-- Items table -->
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-lg font-bold text-gray-900">@T["Order.OrderItems"]</h2>
                <span class="text-sm text-gray-400">@T["Order.ItemCount", Model.ItemCount]</span>
            </div>

            <div class="divide-y divide-gray-100">
                @foreach (var item in Model.Items)
                {
                    <div class="px-6 py-4 flex items-center gap-4">
                        <!-- Product icon placeholder -->
                        <div class="w-14 h-14 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>

                        <!-- Info -->
                        <div class="flex-1 min-w-0">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                               class="text-sm font-semibold text-gray-900 hover:text-brand-700 transition line-clamp-1">
                                @item.ProductName
                            </a>
                            <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
                                @if (!string.IsNullOrWhiteSpace(item.ProductSku))
                                {
                                    <span>@T["Product.Sku", item.ProductSku]</span>
                                    <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                                }
                                <span>@T["Order.PriceQuantity", item.UnitPrice.ToString("N0"), item.Quantity]</span>
                            </div>
                        </div>

                        <!-- Line total -->
                        <div class="text-right shrink-0">
                            <div class="text-base font-bold text-gray-900">@item.LineTotal.ToString("N0")</div>
                            <div class="text-xs text-gray-400">VND</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary row -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 space-y-2 text-sm">
                <div class="flex items-center justify-between">
                    <span class="font-semibold text-gray-700">@T["Label.Subtotal"]</span>
                    <span class="font-semibold text-gray-900">@Model.Subtotal.ToString("N0") @Model.CurrencyCode</span>
                </div>
                <div class="flex items-center justify-between text-gray-600">
                    <span>@T["Summary.Discount"]</span>
                    <span>-@Model.DiscountAmount.ToString("N0") @Model.CurrencyCode</span>
                </div>
                <div class="flex items-center justify-between text-gray-600">
                    <span>@T["Summary.Shipping"]</span>
                    <span>@Model.ShippingFee.ToString("N0") @Model.CurrencyCode</span>
                </div>
                <div class="flex items-center justify-between text-gray-600">
                    <span>@T["Summary.Tax", Model.TaxRate.ToString("0.##")]</span>
                    <span>@Model.TaxAmount.ToString("N0") @Model.CurrencyCode</span>
                </div>
                <div class="flex items-center justify-between border-t border-gray-200 pt-2">
                    <span class="text-sm font-semibold text-gray-700">@T["Label.Total"]</span>
                    <span class="text-xl font-extrabold text-brand-600">@Model.TotalAmount.ToString("N0") <span class="text-sm font-medium text-gray-400">@Model.CurrencyCode</span></span>
                </div>
            </div>
        </section>

        <!-- Sidebar: shipping + order info -->
        <div class="space-y-6">

            <!-- Shipping info -->
            <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">@T["Order.ShippingAddress"]</h2>
                </div>
                <div class="px-5 py-4 text-sm space-y-2.5">
                    <div class="flex items-center gap-3">
                        <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span class="font-semibold text-gray-900">@Model.ShippingFullName</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <span class="text-gray-600">@Model.ShippingEmail</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <span class="text-gray-600">@Model.ShippingPhone</span>
                    </div>
                    <div class="border-t border-dashed border-gray-200 pt-2.5 mt-1">
                        <div class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-gray-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                            <div class="text-gray-600 leading-relaxed">
                                <div>@Model.ShippingAddress</div>
                                @if (!string.IsNullOrWhiteSpace(Model.ShippingWard))
                                {
                                    <div>@Model.ShippingWard</div>
                                }
                                <div>@Model.ShippingProvince</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Delivery notes -->
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">@T["Order.DeliveryNotes"]</h2>
                    </div>
                    <div class="px-5 py-4">
                        <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-line">@Model.Notes</p>
                    </div>
                </section>
            }

            <!-- Quick actions -->
            <div class="bg-gradient-to-br from-gray-50 to-white rounded-2xl border border-gray-100 p-5">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">@T["Order.QuickActions"]</h3>
                <div class="space-y-2">
                    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                        <div class="px-5 py-4 border-b border-gray-100">
                            <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">@T["Order.PaymentSnapshot"]</h2>
                        </div>
                        <div class="px-5 py-4 text-sm space-y-2.5 text-gray-600">
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Order.Method"]</span>
                                <span class="font-semibold text-gray-900">@paymentMethodText</span>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Order.Provider"]</span>
                                <span class="font-semibold text-gray-900">@Model.PaymentProvider</span>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Label.Status"]</span>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-@(paymentColor)-100 text-@(paymentColor)-700">@paymentStatusText</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.PaymentTransactionReference))
                            {
                                <div class="border-t border-dashed border-gray-200 pt-2.5 mt-1">
                                    <div class="text-gray-400">@T["Order.TransactionReference"]</div>
                                    <div class="mt-1 font-mono text-xs text-gray-700 break-all">@Model.PaymentTransactionReference</div>
                                </div>
                            }
                        </div>
                    </section>

                    @if (Model.IsRefundReady)
                    {
                        <section class="bg-amber-50 rounded-2xl border border-amber-200 p-4 text-sm text-amber-900">
                            <div class="font-semibold">@T["Order.RefundReadyTitle"]</div>
                            <div class="mt-1">
                                @(Model.RefundReadyAtUtc.HasValue
                                    ? T["Order.RefundReadyDescriptionWithDate", Model.RefundReadyAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")]
                                    : T["Order.RefundReadyDescription"])
                            </div>
                        </section>
                    }

                    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                        <div class="px-5 py-4 border-b border-gray-100">
                            <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">@T["Order.TrackingSnapshot"]</h2>
                        </div>
                        <div class="px-5 py-4 text-sm space-y-2.5 text-gray-600">
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Order.Carrier"]</span>
                                <span class="font-semibold text-gray-900">@(string.IsNullOrWhiteSpace(Model.ShipmentCarrier) ? T["Order.Pending"].Value : Model.ShipmentCarrier)</span>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Order.TrackingNumber"]</span>
                                <span class="font-mono text-xs font-semibold text-gray-900 break-all">@(string.IsNullOrWhiteSpace(Model.TrackingNumber) ? T["Order.Pending"].Value : Model.TrackingNumber)</span>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <span>@T["Order.EstimatedDelivery"]</span>
                                <span class="font-semibold text-gray-900">@(Model.EstimatedDeliveryDateUtc.HasValue ? Model.EstimatedDeliveryDateUtc.Value.ToLocalTime().ToString("dd MMM yyyy") : T["Order.Pending"].Value)</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.TrackingUrl))
                            {
                                <a href="@Model.TrackingUrl" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold">
                                    @T["Order.OpenCarrierTracking"]
                                </a>
                            }
                        </div>
                    </section>

                    <a asp-controller="Order" asp-action="Tracking" asp-route-id="@Model.OrderId"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:border-brand-200 hover:bg-brand-50 hover:text-brand-700 transition">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 01.553-.894L9 2m0 18l6-2m-6 2V2m6 16l6-2m-6 2V2m6 14V4m0 0l-6-2m6 2L9 2"/></svg>
                        @T["Order.TrackShipment"]
                    </a>
                    <a asp-controller="Product" asp-action="Index"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:border-brand-200 hover:bg-brand-50 hover:text-brand-700 transition">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                        @T["Order.BrowseMoreProducts"]
                    </a>
                    <a asp-controller="Home" asp-action="Index"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:border-brand-200 hover:bg-brand-50 hover:text-brand-700 transition">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        @T["Order.BackToHomepage"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>