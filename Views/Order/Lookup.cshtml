@model ASPNET_Ecommerce.Models.ViewModels.Order.OrderLookupViewModel
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Order.Lookup.Title"];
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="max-w-3xl mx-auto">
    <div class="rounded-3xl bg-gradient-to-br from-brand-600 via-brand-700 to-slate-900 px-6 py-10 text-white shadow-xl sm:px-10">
        <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-100">@T["Order.Lookup.Badge"]</p>
            <h1 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">@T["Order.Lookup.HeroTitle"]</h1>
            <p class="mt-3 text-sm text-brand-100 sm:text-base">@T["Order.Lookup.Description"]</p>
        </div>
    </div>

    <div class="mt-8 rounded-3xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8">
        <form asp-action="Lookup" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div>
                <label asp-for="OrderNumber" class="mb-2 block text-sm font-semibold text-gray-800">@T["Order.Lookup.OrderNumberLabel"]</label>
                <input asp-for="OrderNumber" class="block w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm font-mono uppercase tracking-wide focus:border-brand-500 focus:ring-brand-500" placeholder="@T["Order.Lookup.OrderNumberPlaceholder"]" />
                <span asp-validation-for="OrderNumber" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Email" class="mb-2 block text-sm font-semibold text-gray-800">@T["Order.Lookup.EmailLabel"]</label>
                <input asp-for="Email" class="block w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-brand-500 focus:ring-brand-500" placeholder="@T["Order.Lookup.EmailPlaceholder"]" />
                <span asp-validation-for="Email" class="mt-1 block text-sm text-red-600"></span>
                <p class="mt-2 text-sm text-gray-500">
                    @if (isAuthenticated)
                    {
                        <text>@T["Order.Lookup.AuthHint"]</text>
                    }
                    else
                    {
                        <text>@T["Order.Lookup.GuestHint"]</text>
                    }
                </p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700">
                    @T["Order.Lookup.Submit"]
                </button>
                @if (isAuthenticated)
                {
                    <a asp-controller="Order" asp-action="Index" class="text-sm font-medium text-gray-600 transition hover:text-brand-700">@T["Order.Lookup.BackToOrders"]</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}