@model IReadOnlyList<ASPNET_Ecommerce.Models.ViewModels.Order.OrderHistoryItemViewModel>
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Nav.MyOrders"];
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">@T["Nav.MyOrders"]</h1>
        <p class="text-sm text-gray-500 mt-1">@T["Order.Index.Description"]</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <a asp-controller="Order" asp-action="Lookup"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
            @T["Order.LookupByCode"]
        </a>
        <a asp-controller="Product" asp-action="Index"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            @T["Action.ContinueShopping"]
        </a>
    </div>
</div>

<div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 border-b border-gray-100 text-xs uppercase tracking-wider text-gray-500">
                <tr>
                    <th class="px-6 py-4">@T["Label.Order"]</th>
                    <th class="px-6 py-4">@T["Label.Placed"]</th>
                    <th class="px-6 py-4">@T["Label.Status"]</th>
                    <th class="px-6 py-4">@T["Label.Items"]</th>
                    <th class="px-6 py-4">@T["Label.Total"]</th>
                    <th class="px-6 py-4 text-right">@T["Label.Actions"]</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="px-6 py-16 text-center">
                            <div class="max-w-md mx-auto">
                                <div class="mx-auto w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center text-gray-400 mb-4">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                </div>
                                <h2 class="text-lg font-semibold text-gray-900">@T["Order.Index.EmptyTitle"]</h2>
                                <p class="mt-2 text-sm text-gray-500">@T["Order.Index.EmptyDescription"]</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var order in Model)
                    {
                        var statusClasses = order.Status switch
                        {
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Pending => "bg-amber-100 text-amber-800",
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Processing => "bg-blue-100 text-blue-800",
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Completed => "bg-emerald-100 text-emerald-800",
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Cancelled => "bg-red-100 text-red-800",
                            _ => "bg-gray-100 text-gray-700"
                        };

                        var orderStatusText = order.Status switch
                        {
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Pending => T["Order.Status.Pending"].Value,
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Processing => T["Order.Status.Processing"].Value,
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Completed => T["Order.Status.Completed"].Value,
                            ASPNET_Ecommerce.Models.Orders.OrderStatus.Cancelled => T["Order.Status.Cancelled"].Value,
                            _ => order.Status.ToString()
                        };

                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <div class="font-semibold text-gray-900">@order.OrderNumber</div>
                                <div class="text-xs text-gray-400 mt-1">@T["Order.Reference", order.OrderId]</div>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@order.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @statusClasses">@orderStatusText</span>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@order.ItemCount</td>
                            <td class="px-6 py-4 font-semibold text-gray-900">
                                <div>@order.TotalAmount.ToString("N0") VND</div>
                                @if (order.IsRefundReady)
                                {
                                    <div class="mt-1 text-xs font-medium text-amber-700">@T["Order.RefundReady"]</div>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId"
                                       class="inline-flex items-center gap-2 px-3 py-2 text-xs font-semibold text-brand-600 border border-brand-300 rounded-lg hover:bg-brand-50 transition">
                                        @T["Order.ViewDetails"]
                                    </a>
                                    <a asp-controller="Order" asp-action="Tracking" asp-route-id="@order.OrderId"
                                       class="inline-flex items-center gap-2 px-3 py-2 text-xs font-semibold text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                                        @T["Order.Track"]
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>