@model ASPNET_Ecommerce.Models.ViewModels.Cart.CartIndexViewModel
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Cart.Title"];
}

<div class="flex items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">@T["Cart.Title"]</h1>
        <p class="text-sm text-gray-500 mt-1">@T["Cart.ItemsReady", Model.ItemCount]</p>
    </div>
    <a asp-controller="Product" asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        @T["Action.ContinueShopping"]
    </a>
</div>

@if (TempData["CartSuccess"] is string successMessage)
{
    <div class="mb-6 flex items-center gap-2 p-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-xl">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @successMessage
    </div>
}

@if (TempData["CartError"] is string errorMessage)
{
    <div class="mb-6 flex items-center gap-2 p-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-xl">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @errorMessage
    </div>
}

@if (Model.Items.Count == 0)
{
    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-10 sm:p-14 text-center">
        <div class="mx-auto w-20 h-20 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center mb-5">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5H3m4 8l-1.5 7h11l-1.5-7M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">@T["Cart.EmptyTitle"]</h2>
        <p class="text-sm text-gray-500 mt-2 max-w-md mx-auto">@T["Cart.EmptyDescription"]</p>
        <a asp-controller="Product" asp-action="Index"
           class="inline-flex items-center gap-2 mt-6 px-5 py-3 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
            @T["Action.BrowseProducts"]
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_360px] gap-8 items-start">
        <section class="space-y-4">
            @foreach (var item in Model.Items)
            {
                <article class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-5">
                    <div class="flex flex-col sm:flex-row gap-5">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                           class="block shrink-0 w-full sm:w-32 aspect-square rounded-2xl overflow-hidden bg-gray-50 border border-gray-100">
                            @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                            {
                                <img src="@item.ImagePath" alt="@item.ProductName" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-gray-300">
                                    <svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                </div>
                            }
                        </a>

                        <div class="flex-1 min-w-0">
                            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                <div>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                       class="text-lg font-semibold text-gray-900 hover:text-brand-700 transition line-clamp-2">@item.ProductName</a>
                                    @if (!string.IsNullOrWhiteSpace(item.ProductSku))
                                    {
                                        <p class="text-sm text-gray-400 mt-1">@T["Label.Sku", item.ProductSku]</p>
                                    }
                                    <p class="text-sm text-gray-500 mt-2">@T["Cart.AvailableStock", item.AvailableStock]</p>
                                </div>
                                <div class="text-left sm:text-right">
                                    <div class="text-sm text-gray-400">@T["Cart.UnitPrice"]</div>
                                    <div class="text-lg font-bold text-brand-600">@item.UnitPrice.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                                    @if (item.IsDiscountActive)
                                    {
                                        <div class="text-xs text-gray-400 line-through">@item.OriginalUnitPrice.ToString("N0") VND</div>
                                    }
                                </div>
                            </div>

                            <div class="mt-5 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
                                <form asp-controller="Cart" asp-action="Update" method="post" class="flex items-end gap-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ProductId" value="@item.ProductId" />
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1" for="quantity-@item.ProductId">@T["Label.Quantity"]</label>
                                        <input id="quantity-@item.ProductId" name="Quantity" type="number" min="1" max="@item.AvailableStock" value="@item.Quantity"
                                               class="w-24 rounded-xl border border-gray-300 bg-white px-3 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                                    </div>
                                    <button type="submit"
                                            class="px-4 py-2.5 text-sm font-semibold text-brand-700 bg-brand-50 rounded-xl hover:bg-brand-100 transition">
                                        @T["Action.Update"]
                                    </button>
                                </form>

                                <div class="flex items-center justify-between lg:justify-end gap-4">
                                    <div class="text-right">
                                        <div class="text-sm text-gray-400">@T["Cart.LineTotal"]</div>
                                        <div class="text-xl font-bold text-gray-900">@item.LineTotal.ToString("N0") <span class="text-xs font-normal text-gray-400">VND</span></div>
                                    </div>
                                    <form asp-controller="Cart" asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 rounded-xl hover:bg-red-100 transition">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V4h6v3m-7 4v6m4-6v6m4-10v12a2 2 0 01-2 2H8a2 2 0 01-2-2V7h12z"/></svg>
                                            @T["Action.Remove"]
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </section>

        <aside class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sticky top-24">
            <h2 class="text-xl font-bold text-gray-900">@T["Cart.OrderSummary"]</h2>
            <div class="mt-6 space-y-4">
                <div class="flex items-center justify-between text-sm text-gray-500">
                    <span>@T["Label.Items"]</span>
                    <span>@Model.ItemCount</span>
                </div>
                <div class="flex items-center justify-between text-sm text-gray-500">
                    <span>@T["Label.Subtotal"]</span>
                    <span>@Model.Subtotal.ToString("N0") VND</span>
                </div>
                <div class="border-t border-dashed border-gray-200 pt-4 flex items-center justify-between">
                    <span class="text-base font-semibold text-gray-900">@T["Cart.EstimatedTotal"]</span>
                    <span class="text-2xl font-bold text-brand-600">@Model.Subtotal.ToString("N0") <span class="text-sm font-medium text-gray-400">VND</span></span>
                </div>
            </div>

            <a asp-controller="Order" asp-action="Checkout"
               class="mt-6 w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
                @T["Action.ProceedToCheckout"]
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <p class="mt-3 text-xs text-gray-400 leading-relaxed">@T["Cart.SignInRequiredCheckout"]</p>
            }
        </aside>
    </div>
}
