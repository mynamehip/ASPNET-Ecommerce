@inject ASPNET_Ecommerce.Services.ICartService CartService
@inject ASPNET_Ecommerce.Services.ISystemSettingService SystemSettingService
@inject ASPNET_Ecommerce.Services.IWishlistService WishlistService
@inject Microsoft.Extensions.Localization.IStringLocalizer<ASPNET_Ecommerce.SharedResource> T
@using System.Globalization

@{
    var cartItemCount = await CartService.GetItemCountAsync();
    var siteSettings = await SystemSettingService.GetPublicAsync();
    var adminLandingController = User.IsInRole("Admin") ? "Dashboard" : "Products";
    var currentUiCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var wishlistItemCount = await WishlistService.GetItemCountAsync();
}

<!DOCTYPE html>
<html lang="@currentUiCulture" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(string.IsNullOrWhiteSpace(siteSettings.SeoMetaTitle) ? siteSettings.StoreName : siteSettings.SeoMetaTitle)</title>
    @if (!string.IsNullOrWhiteSpace(siteSettings.SeoMetaDescription))
    {
        <meta name="description" content="@siteSettings.SeoMetaDescription" />
    }
    <script>
        (function () {
            const storedTheme = localStorage.getItem("theme");
            const shouldUseDark = storedTheme === "dark" || (!storedTheme && window.matchMedia("(prefers-color-scheme: dark)").matches);
            if (shouldUseDark) {
                document.documentElement.classList.add("dark");
            }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body class="flex flex-col min-h-full bg-gray-50 font-sans text-gray-800" data-notifications-enabled="@(User.Identity?.IsAuthenticated ?? false ? "true" : "false")" data-notifications-title="@T["Notifications.Title"]">

    <!-- Navbar -->
    <nav class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between gap-3 h-16">
                <!-- Brand -->
                     <a asp-area="" asp-controller="Home" asp-action="Index"
                         class="flex min-w-0 items-center gap-2 text-xl font-extrabold text-brand-600 tracking-tight hover:text-brand-700 transition">
                    @if (!string.IsNullOrWhiteSpace(siteSettings.LogoImagePath))
                    {
                        <img src="@siteSettings.LogoImagePath" alt="@siteSettings.StoreName" class="w-8 h-8 object-contain rounded-md" />
                    }
                    else
                    {
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5H3m4 8l-1.5 7h11l-1.5-7M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/></svg>
                    }
                    <span class="truncate">@siteSettings.StoreName</span>
                </a>

                <!-- Desktop nav -->
                <div class="hidden md:flex flex-1 items-center justify-center gap-1">
                    <a asp-area="" asp-controller="Home" asp-action="Index"
                       class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition">@T["Nav.Home"]</a>
                    <a asp-area="" asp-controller="Product" asp-action="Index"
                       class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition">@T["Nav.Products"]</a>
                          <a asp-area="" asp-controller="Order" asp-action="Lookup"
                              class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition">Track order</a>
                </div>

                <!-- Right side -->
                <div class="flex shrink-0 items-center gap-2">
                    <form asp-controller="Language" asp-action="Switch" method="post" class="hidden lg:flex items-center gap-1 rounded-lg border border-gray-200 bg-white p-0.5">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" name="culture" value="en" class="px-2.5 py-1.5 rounded-md text-xs font-semibold transition @(currentUiCulture == "en" ? "bg-brand-600 text-white" : "text-gray-600 hover:bg-gray-100")">EN</button>
                        <button type="submit" name="culture" value="vi" class="px-2.5 py-1.5 rounded-md text-xs font-semibold transition @(currentUiCulture == "vi" ? "bg-brand-600 text-white" : "text-gray-600 hover:bg-gray-100")">VI</button>
                    </form>

                    <button type="button"
                            class="theme-toggle inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-200 bg-white text-gray-600 hover:text-amber-600 hover:border-amber-200 hover:bg-amber-50 transition"
                            aria-label="@T["Theme.Toggle"]">
                        <svg class="theme-icon-sun w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 10-1.414 1.414zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 6a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zm-4.95-2.464a1 1 0 10-1.414 1.414l.707.707a1 1 0 001.414-1.414l-.707-.707zM4 11a1 1 0 100-2H3a1 1 0 100 2h1zm1.757-6.657a1 1 0 010 1.414l-.707.707A1 1 0 013.636 5.05l.707-.707a1 1 0 011.414 0zm8.486 0a1 1 0 011.414 0l.707.707A1 1 0 1114.95 6.464l-.707-.707a1 1 0 010-1.414z"/></svg>
                        <svg class="theme-icon-moon w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
                    </button>

                    <a asp-controller="Wishlist" asp-action="Index"
                        class="relative inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-200 bg-white text-gray-600 hover:text-rose-600 hover:border-rose-200 hover:bg-rose-50 transition"
                        aria-label="Open wishlist">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
                        <span id="wishlist-badge-count" class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-rose-600 text-white text-[11px] font-bold items-center justify-center @(wishlistItemCount > 0 ? "flex" : "hidden")">@wishlistItemCount</span>
                    </a>

                    <a asp-controller="Cart" asp-action="Index"
                    class="relative inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-200 bg-white text-gray-600 hover:text-brand-700 hover:border-brand-200 hover:bg-brand-50 transition"
                    aria-label="@T["Nav.OpenCart"]">
                        
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5H3m4 8l-1.5 7h11l-1.5-7M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/>
                        </svg>

                        @if (cartItemCount > 0)
                        {
                            <span class="absolute top-0 right-0 w-5 h-5 px-1 bg-red-500 text-white rounded-full text-[10px] font-bold flex items-center justify-center">
                                @cartItemCount
                            </span>
                        }
                    </a>


                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <details class="relative hidden md:block group">
                            <summary class="flex list-none items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-700 hover:border-brand-200 hover:bg-brand-50 transition cursor-pointer">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
                                <span class="hidden lg:inline max-w-28 truncate">@User.Identity!.Name</span>
                                <svg class="hidden lg:block w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                            </summary>
                            <div class="absolute right-0 mt-2 w-56 overflow-hidden rounded-xl border border-gray-200 bg-white py-1 shadow-lg z-50">
                                <div class="px-4 py-3 border-b border-gray-100 bg-gray-50">
                                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">@T["Nav.MyAccount"]</p>
                                    <p class="mt-1 text-sm font-medium text-gray-900 truncate">@User.Identity!.Name</p>
                                </div>
                                <a asp-area="" asp-controller="Profile" asp-action="Index" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    @T["Nav.MyProfile"]
                                </a>
                                <a asp-area="" asp-controller="Order" asp-action="Index" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                                    @T["Nav.MyOrders"]
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                {
                                    <div class="border-t border-gray-100 my-1"></div>
                                    <a asp-area="Admin" asp-controller="@adminLandingController" asp-action="Index" class="flex items-center gap-2 px-4 py-2.5 text-sm text-brand-600 hover:bg-brand-50">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                        @T["Nav.AdminPanel"]
                                    </a>
                                }
                                <div class="border-t border-gray-100 my-1"></div>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0 lg:hidden">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1"/></svg>
                                        @T["Nav.Logout"]
                                    </button>
                                </form>
                            </div>
                        </details>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="hidden lg:block">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="inline-flex items-center gap-2 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-100 transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1"/></svg>
                                <span>@T["Nav.Logout"]</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login"
                           class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-lg hover:text-gray-900 hover:bg-gray-100 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H3m0 0l4-4m-4 4l4 4m8-10h2a2 2 0 012 2v8a2 2 0 01-2 2h-2"/></svg>
                            <span>@T["Nav.Login"]</span>
                        </a>
                        <a asp-controller="Auth" asp-action="Register"
                           class="inline-flex px-3 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 shadow-sm transition">@T["Nav.Register"]</a>
                    }

                    <!-- Mobile toggle -->
                    <button data-collapse-toggle="mobile-menu" type="button"
                            class="md:hidden p-2 text-gray-500 rounded-lg hover:bg-gray-100"
                            aria-controls="mobile-menu" aria-expanded="false">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    </button>
                </div>
            </div>

            <!-- Mobile menu -->
            <div class="hidden md:hidden pb-3" id="mobile-menu">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">@T["Nav.Home"]</a>
                <a asp-area="" asp-controller="Product" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">@T["Nav.Products"]</a>
                <a asp-area="" asp-controller="Order" asp-action="Lookup" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">Track order</a>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="border-t border-gray-100 my-2"></div>
                    <div class="px-3 py-1 text-xs font-semibold text-gray-400 uppercase">@T["Nav.MyAccount"]</div>
                    <a asp-area="" asp-controller="Profile" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">@T["Nav.MyProfile"]</a>
                    <a asp-area="" asp-controller="Order" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">@T["Nav.MyOrders"]</a>
                    <a asp-area="" asp-controller="Wishlist" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">
                        @T["Nav.Wishlist"]
                        <span id="wishlist-menu-count" class="ml-1 items-center px-2 py-0.5 rounded-full text-xs font-medium bg-rose-100 text-rose-800 @(wishlistItemCount > 0 ? "inline-flex" : "hidden")">@wishlistItemCount</span>
                    </a>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <div class="border-t border-gray-100 my-2"></div>
                    <a asp-area="Admin" asp-controller="@adminLandingController" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm font-medium text-brand-600 hover:bg-brand-50">@T["Nav.AdminPanel"]</a>
                }
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="border-t border-gray-100 my-2"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="px-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full text-left px-3 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50">
                            @T["Nav.Logout"]
                        </button>
                    </form>
                }
                else
                {
                    <div class="border-t border-gray-100 my-2"></div>
                    <a asp-controller="Auth" asp-action="Login" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100">@T["Nav.Login"]</a>
                    <a asp-controller="Auth" asp-action="Register" class="block px-3 py-2 rounded-lg text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 mx-3">@T["Nav.Register"]</a>
                }
                <form asp-controller="Language" asp-action="Switch" method="post" class="mt-3 flex items-center gap-2 px-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit" name="culture" value="en" class="flex-1 px-3 py-2 rounded-lg text-xs font-semibold transition @(currentUiCulture == "en" ? "bg-brand-600 text-white" : "bg-white border border-gray-200 text-gray-700")">EN</button>
                    <button type="submit" name="culture" value="vi" class="flex-1 px-3 py-2 rounded-lg text-xs font-semibold transition @(currentUiCulture == "vi" ? "bg-brand-600 text-white" : "bg-white border border-gray-200 text-gray-700")">VI</button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-white mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-500">
            <span>&copy; 2026 @siteSettings.StoreName. @T["Footer.RightsReserved"]</span>
            <div class="flex items-center gap-4">
                <a asp-area="" asp-controller="Order" asp-action="Lookup" class="hover:text-brand-600 transition">Track order</a>
                <a href="mailto:@siteSettings.SupportEmail" class="hover:text-brand-600 transition">@siteSettings.SupportEmail</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-brand-600 transition">@T["Footer.Privacy"]</a>
            </div>
        </div>
    </footer>

    <div id="notification-host" class="fixed top-20 right-4 z-[70] flex flex-col gap-3 max-w-sm pointer-events-none"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.5.2/flowbite.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
