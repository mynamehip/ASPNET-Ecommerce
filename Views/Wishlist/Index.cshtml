@model ASPNET_Ecommerce.Models.ViewModels.Wishlist.WishlistIndexViewModel

@{
    ViewData["Title"] = "My Wishlist";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">My Wishlist</h1>
        <p class="text-sm text-gray-500 mt-1">Save products for later and jump back into checkout when you are ready.</p>
    </div>
    <a asp-controller="Product" asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
        Browse products
    </a>
</div>

@if (Model.ItemCount == 0)
{
    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm px-6 py-16 text-center">
        <div class="mx-auto w-16 h-16 rounded-2xl bg-rose-50 flex items-center justify-center text-rose-500 mb-4">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900">Your wishlist is empty</h2>
        <p class="mt-2 text-sm text-gray-500">Save products from the catalog to compare and buy later.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        @foreach (var item in Model.Items)
        {
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="block aspect-square bg-gray-50 overflow-hidden">
                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                    {
                        <img src="@item.ImagePath" alt="@item.ProductName" class="w-full h-full object-cover hover:scale-105 transition duration-300" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center text-gray-300">
                            <svg class="w-16 h-16" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    }
                </a>
                <div class="p-5 flex-1 flex flex-col">
                    @if (!string.IsNullOrWhiteSpace(item.CategoryName))
                    {
                        <div class="text-xs font-semibold uppercase tracking-wider text-brand-600">@item.CategoryName</div>
                    }
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="mt-2 text-lg font-bold text-gray-900 hover:text-brand-700 transition">@item.ProductName</a>
                    @if (!string.IsNullOrWhiteSpace(item.ProductSku))
                    {
                        <div class="mt-2 text-xs text-gray-400">SKU: @item.ProductSku</div>
                    }
                    <div class="mt-4">
                        <div class="text-2xl font-extrabold text-brand-600">@item.EffectivePrice.ToString("N0") <span class="text-sm font-medium text-gray-400">VND</span></div>
                        @if (item.IsDiscountActive)
                        {
                            <div class="text-xs text-gray-400 line-through">@item.OriginalPrice.ToString("N0") VND</div>
                            <div class="mt-1 inline-flex rounded-full bg-amber-100 px-2.5 py-1 text-[11px] font-semibold text-amber-800">-@item.DiscountPercentage?.ToString("0.##")%</div>
                        }
                    </div>
                    <div class="mt-2 text-sm @(item.IsActive && item.StockQuantity > 0 ? "text-emerald-600" : "text-red-500")">
                        @(item.IsActive && item.StockQuantity > 0 ? $"In stock ({item.StockQuantity})" : "Currently unavailable")
                    </div>
                    <div class="mt-1 text-xs text-gray-400">Saved @item.AddedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
                    <div class="mt-5 grid grid-cols-2 gap-3">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                           class="inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
                            View product
                        </a>
                        <form asp-controller="Wishlist" asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductId" value="@item.ProductId" />
                            <input type="hidden" name="ReturnUrl" value="@Url.Action("Index", "Wishlist")" />
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition">
                                Remove
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
