@model ASPNET_Ecommerce.Models.ViewModels.Profile.ProfilePageViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">My Profile</h1>
        <p class="text-sm text-gray-500 mt-1">Manage your account details and keep your sign-in credentials current.</p>
    </div>
    <a asp-controller="Order" asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
        View my orders
    </a>
</div>

@if (TempData["ProfileStatusMessage"] is string profileStatusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @profileStatusMessage
    </div>
}

@if (TempData["ProfileErrorMessage"] is string profileErrorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @profileErrorMessage
    </div>
}

@if (TempData["PasswordStatusMessage"] is string passwordStatusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @passwordStatusMessage
    </div>
}

@if (TempData["PasswordErrorMessage"] is string passwordErrorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @passwordErrorMessage
    </div>
}

<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(360px,0.9fr)] gap-6">
    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <div class="flex items-center justify-between gap-4 mb-5">
            <div>
                <h2 class="text-lg font-bold text-gray-900">Account Details</h2>
                <p class="text-sm text-gray-500 mt-1">Update the customer information used for checkout and account communication.</p>
            </div>
            <div class="text-right text-xs text-gray-400">
                <div>Joined</div>
                <div class="mt-1 text-sm font-medium text-gray-700">@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mb-5">
            @foreach (var role in Model.Roles)
            {
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @(role == "Admin" ? "bg-red-100 text-red-700" : role == "Employee" ? "bg-blue-100 text-blue-700" : "bg-gray-100 text-gray-700")">@role</span>
            }
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @(Model.EmailConfirmed ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                @(Model.EmailConfirmed ? "Email confirmed" : "Email pending")
            </span>
        </div>

        <form asp-controller="Profile" asp-action="Index" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"></div>

            <div>
                <label asp-for="ProfileForm.FullName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ProfileForm.FullName" autocomplete="name" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ProfileForm.FullName" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="ProfileForm.Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ProfileForm.Email" autocomplete="email" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ProfileForm.Email" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="ProfileForm.PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ProfileForm.PhoneNumber" autocomplete="tel" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ProfileForm.PhoneNumber" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="pt-4 border-t border-gray-100">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">Default Checkout Address</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label asp-for="ProfileForm.DefaultAddress" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="ProfileForm.DefaultAddress" autocomplete="street-address" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                        <span asp-validation-for="ProfileForm.DefaultAddress" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="ProfileForm.DefaultWard" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="ProfileForm.DefaultWard" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                        <span asp-validation-for="ProfileForm.DefaultWard" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="ProfileForm.DefaultProvince" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="ProfileForm.DefaultProvince" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                        <span asp-validation-for="ProfileForm.DefaultProvince" class="text-red-500 text-sm mt-1"></span>
                    </div>
                </div>
            </div>

            <button type="submit"
                    class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
                Save profile
            </button>
        </form>
    </section>

    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900">Change Password</h2>
        <p class="text-sm text-gray-500 mt-1">Rotate your credentials without leaving the current signed-in session.</p>

        <form asp-controller="Profile" asp-action="ChangePassword" method="post" class="mt-5 space-y-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"></div>

            <div>
                <label asp-for="ChangePasswordForm.CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ChangePasswordForm.CurrentPassword" autocomplete="current-password" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ChangePasswordForm.CurrentPassword" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="ChangePasswordForm.NewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ChangePasswordForm.NewPassword" autocomplete="new-password" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ChangePasswordForm.NewPassword" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="ChangePasswordForm.ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ChangePasswordForm.ConfirmPassword" autocomplete="new-password" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="ChangePasswordForm.ConfirmPassword" class="text-red-500 text-sm mt-1"></span>
            </div>

            <button type="submit"
                    class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-gray-900 rounded-xl hover:bg-black transition">
                Change password
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}