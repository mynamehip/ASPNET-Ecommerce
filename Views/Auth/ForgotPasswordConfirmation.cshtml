@model ASPNET_Ecommerce.Models.ViewModels.Auth.ForgotPasswordConfirmationViewModel

@{
    ViewData["Title"] = "Recovery Requested";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="w-full max-w-2xl">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-emerald-100 rounded-full mb-4">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Recovery flow created</h1>
                <p class="text-gray-500 mt-1">If the email exists in the system, the password reset flow is now available.</p>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5 text-sm text-gray-600 leading-7">
                For security, the application does not reveal whether the submitted email belongs to an account. In a production-ready setup, this is where an email delivery step would happen.
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.DevelopmentResetUrl))
            {
                <div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-5">
                    <div class="text-sm font-semibold text-amber-900">Development preview</div>
                    <p class="mt-2 text-sm text-amber-800">Because the app is running in development mode and no email service is configured yet, you can continue with this generated reset link:</p>
                    <a href="@Model.DevelopmentResetUrl" class="mt-3 inline-flex break-all text-sm font-semibold text-brand-700 hover:text-brand-800">@Model.DevelopmentResetUrl</a>
                </div>
            }

            <div class="mt-6 text-center">
                <a asp-action="Login" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition">Return to sign in</a>
            </div>
        </div>
    </div>
</div>