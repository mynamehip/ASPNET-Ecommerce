@model ASPNET_Ecommerce.Models.ViewModels.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 rounded-full mb-4">
                    <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0-1.657 1.343-3 3-3s3 1.343 3 3c0 1.305-.835 2.416-2 2.829V16a1 1 0 11-2 0v-2.171A2.994 2.994 0 0112 11zm0 0V9a4 4 0 118 0v2m-13 9h10a2 2 0 002-2v-5a2 2 0 00-2-2H7a2 2 0 00-2 2v5a2 2 0 002 2z"/></svg>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Reset your password</h1>
                <p class="text-gray-500 mt-1">Enter your account email and we will prepare a reset flow.</p>
            </div>

            <form asp-action="ForgotPassword" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm bg-red-50 rounded-lg p-3"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Email" autocomplete="email"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm mt-1"></span>
                </div>

                <button type="submit"
                        class="w-full py-2.5 px-4 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 focus:ring-4 focus:ring-brand-200 transition">
                    Continue
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-500">
                Remembered your password?
                <a asp-action="Login" class="font-semibold text-brand-600 hover:text-brand-700">Back to sign in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}