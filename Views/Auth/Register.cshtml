@model ASPNET_Ecommerce.Models.ViewModels.Auth.RegisterViewModel
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Nav.Register"];
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="w-full max-w-lg">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-emerald-100 rounded-full mb-4">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">@T["Auth.CreateAccountTitle"]</h1>
                <p class="text-gray-500 mt-1">@T["Auth.JoinAndStartShopping"]</p>
            </div>

            <form asp-action="Register" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm bg-red-50 rounded-lg p-3"></div>

                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="FullName" autocomplete="name"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                    <span asp-validation-for="FullName" class="text-red-500 text-sm mt-1"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Email" autocomplete="email"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm mt-1"></span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="Password" autocomplete="new-password"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                        <span asp-validation-for="Password" class="text-red-500 text-sm mt-1"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="ConfirmPassword" autocomplete="new-password"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm mt-1"></span>
                    </div>
                </div>

                <button type="submit"
                        class="w-full py-2.5 px-4 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 focus:ring-4 focus:ring-brand-200 transition">
                    @T["Action.CreateAccount"]
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-500">
                @T["Auth.AlreadyHaveAccount"]
                <a asp-action="Login" class="font-semibold text-brand-600 hover:text-brand-700">@T["Action.SignIn"]</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}