@model ASPNET_Ecommerce.Models.ViewModels.Admin.ReviewAdminListViewModel

@{
    ViewData["Title"] = "Reviews";
}

<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Reviews</h1>
        <p class="text-sm text-gray-500 mt-1">Manage published customer reviews, hide inappropriate ones, and reply when needed.</p>
    </div>

    <form asp-area="Admin" asp-controller="Reviews" asp-action="Index" method="get" class="grid grid-cols-1 sm:grid-cols-[minmax(220px,1fr)_180px_auto] gap-3">
        <input type="text" name="search" value="@Model.Search" placeholder="Search product, user, email, or comment"
               class="rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />

        <select name="status"
                class="rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition">
            <option value="">All statuses</option>
            <option value="Approved" selected="@(Model.Status == ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Approved)">Approved</option>
            <option value="Hidden" selected="@(Model.Status == ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Hidden)">Hidden</option>
        </select>

        <button type="submit"
                class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
            Filter
        </button>
    </form>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @statusMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @errorMessage
    </div>
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4">Product</th>
                    <th class="px-6 py-4">Reviewer</th>
                    <th class="px-6 py-4">Rating</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Comment</th>
                    <th class="px-6 py-4">Submitted</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Reviews.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-400">No reviews matched the current filters.</td>
                    </tr>
                }
                else
                {
                    @foreach (var review in Model.Reviews)
                    {
                        var statusClasses = review.Status switch
                        {
                            ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Pending => "bg-amber-100 text-amber-800",
                            ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Approved => "bg-emerald-100 text-emerald-800",
                            ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Hidden => "bg-gray-100 text-gray-700",
                            _ => "bg-gray-100 text-gray-700"
                        };

                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@review.ProductId"
                                   class="font-semibold text-gray-900 hover:text-brand-700 transition">@review.ProductName</a>
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-900">@review.UserFullName</div>
                                <div class="text-xs text-gray-400 mt-0.5">@review.UserId</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-0.5">
                                    @for (var index = 1; index <= 5; index++)
                                    {
                                        <svg class="w-4 h-4 @(index <= review.Rating ? "text-amber-400" : "text-gray-200")" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @statusClasses">@review.Status</span>
                            </td>
                            <td class="px-6 py-4 text-gray-600 max-w-xs">
                                <div class="line-clamp-2">@(string.IsNullOrWhiteSpace(review.CommentPreview) ? "No comment" : review.CommentPreview)</div>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@review.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a asp-area="Admin" asp-controller="Reviews" asp-action="Details" asp-route-id="@review.ReviewId"
                                                    class="px-3 py-1.5 text-xs font-medium text-brand-600 border border-brand-300 rounded-lg hover:bg-brand-50 transition">Manage</a>
                                    <form asp-area="Admin" asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.ReviewId" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" onclick="return confirm('Delete this review permanently?');" class="px-3 py-1.5 text-xs font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>