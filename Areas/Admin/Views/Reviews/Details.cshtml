@model ASPNET_Ecommerce.Models.ViewModels.Admin.ReviewAdminDetailsViewModel

@{
    ViewData["Title"] = "Review Management";

    var statusColor = Model.Status switch
    {
        ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Pending => "amber",
        ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Approved => "emerald",
        ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Hidden => "gray",
        _ => "gray"
    };
}

<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div>
        <div class="text-sm font-medium text-gray-400 uppercase tracking-wider">Review management</div>
        <h1 class="mt-1 text-2xl font-bold text-gray-900">@Model.ProductName</h1>
        <p class="mt-1 text-sm text-gray-500">Review #@Model.ReviewId by @Model.UserFullName</p>
    </div>
    <a asp-area="Admin" asp-controller="Reviews" asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to reviews
    </a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @statusMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @errorMessage
    </div>
}

<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_360px] gap-6">
    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-lg font-bold text-gray-900">Review Content</h2>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-@(statusColor)-100 text-@(statusColor)-800">@Model.Status</span>
        </div>

        <div class="px-6 py-6 space-y-6">
            <div>
                <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">Product</div>
                <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductId"
                   class="mt-1 inline-flex text-base font-semibold text-brand-600 hover:text-brand-700 transition">@Model.ProductName</a>
            </div>

            <div>
                <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">Rating</div>
                <div class="mt-2 flex items-center gap-0.5">
                    @for (var index = 1; index <= 5; index++)
                    {
                        <svg class="w-5 h-5 @(index <= Model.Rating ? "text-amber-400" : "text-gray-200")" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    }
                    <span class="ml-2 text-sm font-semibold text-gray-700">@Model.Rating/5</span>
                </div>
            </div>

            <div>
                <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">Comment</div>
                <div class="mt-2 rounded-2xl border border-gray-100 bg-gray-50 p-5 text-sm text-gray-700 leading-relaxed whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.Comment) ? "No comment was submitted with this review." : Model.Comment)</div>
            </div>

            <div>
                <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">Admin reply</div>
                <div class="mt-2 rounded-2xl border border-blue-100 bg-blue-50 p-5 text-sm text-gray-700 leading-relaxed whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.AdminReply) ? "No admin reply has been posted yet." : Model.AdminReply)</div>
                @if (Model.AdminRepliedAtUtc.HasValue)
                {
                    <div class="mt-2 text-xs text-gray-500">Replied on @Model.AdminRepliedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
                }
            </div>
        </div>
    </section>

    <div class="space-y-6">
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">Visibility status</div>
                    <span class="inline-flex items-center gap-1.5 mt-2 px-2.5 py-0.5 rounded-full text-xs font-bold bg-@(statusColor)-100 text-@(statusColor)-800">@Model.Status</span>
                </div>
                @if (Model.UpdatedAtUtc.HasValue)
                {
                    <div class="text-right text-xs text-gray-400">
                        <div>Last update</div>
                        <div class="mt-1 text-sm font-medium text-gray-700">@Model.UpdatedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                }
            </div>

            <form asp-area="Admin" asp-controller="Reviews" asp-action="UpdateStatus" asp-route-id="@Model.ReviewId" method="post" class="mt-5 space-y-4">
                @Html.AntiForgeryToken()
                <input asp-for="StatusForm.ReviewId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"></div>

                <div>
                    <label asp-for="StatusForm.Status" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <select asp-for="StatusForm.Status"
                            class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition">
                        <option value="@ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Approved">Approved</option>
                        <option value="@ASPNET_Ecommerce.Models.Catalog.ProductReviewStatus.Hidden">Hidden</option>
                    </select>
                    <span asp-validation-for="StatusForm.Status" class="text-red-500 text-sm mt-1"></span>
                </div>

                <div>
                    <label asp-for="StatusForm.AdminReply" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <textarea asp-for="StatusForm.AdminReply" rows="5"
                              class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-brand-500 focus:ring-brand-500 transition"
                              placeholder="Reply to the customer or leave blank."></textarea>
                    <span asp-validation-for="StatusForm.AdminReply" class="text-red-500 text-sm mt-1"></span>
                </div>

                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
                    Save review changes
                </button>
            </form>

            <form asp-area="Admin" asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.ReviewId" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <button type="submit" onclick="return confirm('Delete this review permanently?');"
                        class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-red-700 bg-red-50 border border-red-200 rounded-xl hover:bg-red-100 transition">
                    Delete review
                </button>
            </form>
        </section>

        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100">
                <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">Reviewer Snapshot</h2>
            </div>
            <div class="px-5 py-4 text-sm space-y-3">
                <div>
                    <div class="text-gray-400">Reviewer</div>
                    <div class="font-semibold text-gray-900">@Model.UserFullName</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.UserEmail))
                {
                    <div>
                        <div class="text-gray-400">Email</div>
                        <div class="text-gray-700">@Model.UserEmail</div>
                    </div>
                }
                <div>
                    <div class="text-gray-400">User Id</div>
                    <div class="font-mono text-xs text-gray-700 break-all">@Model.UserId</div>
                </div>
                <div>
                    <div class="text-gray-400">Submitted</div>
                    <div class="text-gray-700">@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}