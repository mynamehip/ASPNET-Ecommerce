@inject ASPNET_Ecommerce.Services.ISystemSettingService SystemSettingService
@inject IStringLocalizer<SharedResource> T
@using System.Globalization

@{
    var siteSettings = await SystemSettingService.GetPublicAsync();
    var currentUiCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@currentUiCulture" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteSettings.StoreName @T["Admin.Layout.TitleSuffix"]</title>
    @if (!string.IsNullOrWhiteSpace(siteSettings.SeoMetaDescription))
    {
        <meta name="description" content="@siteSettings.SeoMetaDescription" />
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="h-full font-sans bg-gray-100 text-gray-800">

    <!-- Mobile top bar -->
    <div class="lg:hidden sticky top-0 z-40 flex items-center justify-between bg-gray-900 px-4 h-16 shadow-lg">
        <a asp-area="" asp-controller="Home" asp-action="Index"
           class="flex items-center gap-2 text-lg font-bold text-white">
            @if (!string.IsNullOrWhiteSpace(siteSettings.LogoImagePath))
            {
                <img src="@siteSettings.LogoImagePath" alt="@siteSettings.StoreName" class="w-7 h-7 object-contain rounded-md" />
            }
            else
            {
                <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5H3m4 8l-1.5 7h11l-1.5-7M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/></svg>
            }
            @siteSettings.StoreName
        </a>
        <button id="mobile-sidebar-toggle" type="button"
                class="p-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div id="sidebar-overlay" class="hidden fixed inset-0 z-40 bg-black/50 lg:hidden"></div>

    <div class="flex h-full lg:min-h-screen">

        <!-- Sidebar -->
        <aside id="admin-sidebar"
               class="fixed inset-y-0 left-0 z-50 w-64 bg-gray-900 text-gray-300 flex flex-col transform -translate-x-full transition-transform duration-200 ease-in-out lg:translate-x-0 lg:static lg:z-auto">

            <!-- Brand -->
            <div class="flex items-center gap-3 px-6 h-16 border-b border-gray-800 shrink-0">
                @if (!string.IsNullOrWhiteSpace(siteSettings.LogoImagePath))
                {
                    <img src="@siteSettings.LogoImagePath" alt="@siteSettings.StoreName" class="w-7 h-7 object-contain rounded-md" />
                }
                else
                {
                    <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5H3m4 8l-1.5 7h11l-1.5-7M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/></svg>
                }
                <div>
                    <span class="text-base font-bold text-white tracking-tight">@siteSettings.StoreName</span>
                    <span class="block text-[10px] uppercase tracking-widest text-gray-500 font-semibold">@T["Admin.Layout.Panel"]</span>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
                @if (User.IsInRole("Admin"))
                {
                    <p class="px-3 mb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500">@T["Admin.Nav.Overview"]</p>

                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                       class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13h8V3H3v10zm10 8h8V3h-8v18zM3 21h8v-6H3v6z"/></svg>
                        @T["Admin.Nav.Dashboard"]
                    </a>

                    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                       class="mt-1 flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5V4H2v16h5m10 0v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2m12 0H7m10-11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        @T["Admin.Nav.Users"]
                    </a>

                    <div class="pt-4">
                        <p class="px-3 mb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500">@T["Admin.Nav.Catalog"]</p>
                    </div>
                }
                else
                {
                    <p class="px-3 mb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500">@T["Admin.Nav.Catalog"]</p>
                }

                <a asp-area="Admin" asp-controller="Products" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    @T["Admin.Nav.Products"]
                </a>

                <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    @T["Admin.Nav.Categories"]
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="pt-4">
                        <p class="px-3 mb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500">@T["Admin.Nav.Orders"]</p>

                        <a asp-area="Admin" asp-controller="Orders" asp-action="Index"
                           class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            @T["Admin.Nav.Orders"]
                        </a>

                                <a asp-area="Admin" asp-controller="Reviews" asp-action="Index"
                                    class="mt-1 flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                                     <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.364 1.118l1.519 4.674c.3.921-.755 1.688-1.54 1.118L12 17.77a1 1 0 00-1.176 0l-3.975 2.888c-.785.57-1.84-.197-1.54-1.118l1.518-4.674a1 1 0 00-.363-1.118L2.488 10.1c-.783-.57-.38-1.81.588-1.81H7.99a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                                      @T["Admin.Nav.Reviews"]
                                </a>

                        <a asp-area="Admin" asp-controller="Slider" asp-action="Index"
                           class="mt-1 flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 7h14M5 12h14M5 17h14"/></svg>
                            Slider
                        </a>

                        <a asp-area="Admin" asp-controller="Settings" asp-action="Index"
                           class="mt-1 flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317a1 1 0 011.35-.936l1.226.533a1 1 0 00.972-.085l1.07-.731a1 1 0 011.436.287l.735 1.068a1 1 0 00.847.433h1.315a1 1 0 01.982 1.189l-.199 1.28a1 1 0 00.252.843l.91.97a1 1 0 01-.001 1.37l-.91.97a1 1 0 00-.252.843l.199 1.28a1 1 0 01-.982 1.189h-1.315a1 1 0 00-.847.433l-.735 1.068a1 1 0 01-1.436.287l-1.07-.731a1 1 0 00-.972-.085l-1.226.533a1 1 0 01-1.35-.936V18.75a1 1 0 00-.565-.9l-1.165-.582a1 1 0 01-.49-1.263l.47-1.214a1 1 0 00-.1-.95l-.74-1.063a1 1 0 010-1.144l.74-1.063a1 1 0 00.1-.95l-.47-1.214a1 1 0 01.49-1.263l1.165-.582a1 1 0 00.565-.9V4.317z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            @T["Admin.Nav.Settings"]
                        </a>
                    </div>
                }

                <div class="pt-4">
                    <p class="px-3 mb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500">@T["Admin.Nav.General"]</p>

                    <a asp-area="" asp-controller="Home" asp-action="Index"
                       class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        @T["Admin.Nav.ViewStore"]
                    </a>
                </div>
            </nav>

            <!-- User footer -->
            <div class="px-4 py-4 border-t border-gray-800 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center text-sm font-bold text-white">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-200 truncate">@User.Identity?.Name</p>
                        <p class="text-xs text-gray-500 truncate">
                            @(User.IsInRole("Admin") ? T["Admin.Role.Admin"] : T["Admin.Role.Employee"])
                        </p>
                    </div>
                </div>
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-gray-400 rounded-lg border border-gray-700 hover:bg-gray-800 hover:text-white transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1"/></svg>
                        @T["Nav.Logout"]
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main content -->
        <div class="flex-1 flex flex-col min-h-screen lg:min-h-0">

            <!-- Top header -->
            <header class="hidden lg:flex items-center justify-between bg-white border-b border-gray-200 px-8 h-16 shrink-0">
                <div>
                    <h2 class="text-lg font-semibold text-gray-900">@ViewData["Title"]</h2>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-500">@User.Identity?.Name</span>
                    <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center text-xs font-bold text-white">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-auto">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.5.2/flowbite.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const toggle = document.getElementById('mobile-sidebar-toggle');
            const sidebar = document.getElementById('admin-sidebar');
            const overlay = document.getElementById('sidebar-overlay');

            function openSidebar() {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            }

            function closeSidebar() {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            }

            if (toggle) toggle.addEventListener('click', openSidebar);
            if (overlay) overlay.addEventListener('click', closeSidebar);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
