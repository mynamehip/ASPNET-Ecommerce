@model ASPNET_Ecommerce.Models.ViewModels.Admin.UserAdminDetailsViewModel

@{
    ViewData["Title"] = "User Management";

    var roleClasses = Model.CurrentRole switch
    {
        "Admin" => "bg-red-100 text-red-700",
        "Employee" => "bg-blue-100 text-blue-700",
        _ => "bg-gray-100 text-gray-700"
    };
}

<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div>
        <div class="text-sm font-medium text-gray-400 uppercase tracking-wider">User management</div>
        <h1 class="mt-1 text-2xl font-bold text-gray-900">@Model.FullName</h1>
        <p class="mt-1 text-sm text-gray-500">@Model.Email</p>
    </div>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to users
    </a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @statusMessage
    </div>
}

<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.05fr)_minmax(360px,0.95fr)] gap-6">
    <div class="space-y-6">
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Account snapshot</div>
                    <div class="mt-3 flex flex-wrap items-center gap-2">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @roleClasses">@Model.CurrentRole</span>
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @(Model.EmailConfirmed ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                            @(Model.EmailConfirmed ? "Email confirmed" : "Email pending")
                        </span>
                        @if (Model.IsLockedOut)
                        {
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">Locked</span>
                        }
                    </div>
                </div>
                <div class="text-right text-xs text-gray-400">
                    <div>Joined</div>
                    <div class="mt-1 text-sm font-medium text-gray-700">@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</div>
                </div>
            </div>

            @if (Model.IsCurrentUser)
            {
                <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    You are editing your own administrator account. Self-lockout and self-demotion are blocked.
                </div>
            }
        </section>

        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100">
                <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">Commerce Snapshot</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">
                <div class="px-5 py-5">
                    <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Total orders</div>
                    <div class="mt-2 text-3xl font-extrabold text-gray-900">@Model.TotalOrders</div>
                </div>
                <div class="px-5 py-5">
                    <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Completed orders</div>
                    <div class="mt-2 text-3xl font-extrabold text-gray-900">@Model.CompletedOrders</div>
                </div>
                <div class="px-5 py-5">
                    <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Total spent</div>
                    <div class="mt-2 text-3xl font-extrabold text-gray-900">@Model.TotalSpent.ToString("N0")</div>
                    <div class="mt-1 text-xs text-gray-400">VND</div>
                </div>
            </div>
            <div class="px-5 py-4 border-t border-gray-100 text-sm text-gray-500">
                Last order: @(Model.LastOrderAtUtc.HasValue ? Model.LastOrderAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm") : "No orders yet")
            </div>
        </section>
    </div>

    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-center justify-between gap-4 mb-5">
            <div>
                <h2 class="text-lg font-bold text-gray-900">Edit User</h2>
                <p class="text-sm text-gray-500 mt-1">Update identity data, role assignment, and account access state.</p>
            </div>
        </div>

        <form asp-area="Admin" asp-controller="Users" asp-action="Update" asp-route-id="@Model.UserId" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input asp-for="UpdateForm.Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"></div>

            <div>
                <label asp-for="UpdateForm.FullName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="UpdateForm.FullName" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="UpdateForm.FullName" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="UpdateForm.Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="UpdateForm.Email" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="UpdateForm.Email" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="UpdateForm.PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="UpdateForm.PhoneNumber" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition" />
                <span asp-validation-for="UpdateForm.PhoneNumber" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div>
                <label asp-for="UpdateForm.SelectedRole" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <select asp-for="UpdateForm.SelectedRole" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-brand-500 transition">
                    <option value="Admin">Admin</option>
                    <option value="Employee">Employee</option>
                    <option value="User">User</option>
                </select>
                <span asp-validation-for="UpdateForm.SelectedRole" class="text-red-500 text-sm mt-1"></span>
            </div>

            <label class="flex items-start gap-3 rounded-xl border border-gray-200 px-4 py-3 cursor-pointer hover:border-brand-200 transition">
                <input asp-for="UpdateForm.EmailConfirmed" class="mt-1 h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500" />
                <span>
                    <span class="block text-sm font-medium text-gray-800">Email confirmed</span>
                    <span class="block text-sm text-gray-500">Keep this enabled for accounts that should bypass email confirmation state.</span>
                </span>
            </label>

            <label class="flex items-start gap-3 rounded-xl border border-gray-200 px-4 py-3 cursor-pointer hover:border-brand-200 transition">
                <input asp-for="UpdateForm.IsLockedOut" class="mt-1 h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500" />
                <span>
                    <span class="block text-sm font-medium text-gray-800">Lock this account</span>
                    <span class="block text-sm text-gray-500">Locked users cannot sign in until an admin unlocks them.</span>
                </span>
            </label>

            <button type="submit"
                    class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition">
                Save changes
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}