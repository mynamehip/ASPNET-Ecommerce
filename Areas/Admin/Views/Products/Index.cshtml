@model IReadOnlyList<AdminProductListItemViewModel>
@inject IStringLocalizer<SharedResource> T

@{
    ViewData["Title"] = T["Admin.Nav.Products"];
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">@T["Admin.Nav.Products"]</h1>
        <p class="text-sm text-gray-500 mt-1">@T["Admin.Products.Description"]</p>
    </div>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create"
       class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 shadow-sm transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        @T["Action.CreateProduct"]
    </a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @statusMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @errorMessage
    </div>
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4">@T["Label.Product"]</th>
                    <th class="px-6 py-4">@T["Label.Category"]</th>
                    <th class="px-6 py-4">@T["Label.Price"]</th>
                    <th class="px-6 py-4">Discount</th>
                    <th class="px-6 py-4">@T["Label.Stock"]</th>
                    <th class="px-6 py-4">@T["Label.Status"]</th>
                    <th class="px-6 py-4">@T["Label.Images"]</th>
                    <th class="px-6 py-4 text-right">@T["Label.Actions"]</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-gray-400">@T["Admin.Products.Empty"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var product in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(product.PrimaryImagePath))
                                    {
                                        <img src="@product.PrimaryImagePath" alt="@product.Name" class="w-16 h-16 rounded-lg object-cover border border-gray-200" />
                                    }
                                    else
                                    {
                                        <div class="w-16 h-16 rounded-lg border border-gray-200 bg-gray-50 flex items-center justify-center text-xs text-gray-400">@T["Admin.Products.NoImage"]</div>
                                    }
                                    <div>
                                        <div class="font-semibold text-gray-900">@product.Name</div>
                                        <div class="text-xs text-gray-400 mt-0.5">@(string.IsNullOrWhiteSpace(product.Sku) ? T["Admin.Products.NoSku"] : product.Sku)</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@product.CategoryName</td>
                            <td class="px-6 py-4">
                                @if (product.IsDiscountActive)
                                {
                                    <div class="font-semibold text-gray-900">@product.EffectivePrice.ToString("N0")</div>
                                    <div class="text-xs text-gray-400 line-through">@product.OriginalPrice.ToString("N0")</div>
                                }
                                else
                                {
                                    <div class="font-semibold text-gray-900">@product.OriginalPrice.ToString("N0")</div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                @if (product.IsDiscountActive && product.DiscountPercentage.HasValue)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                        -@product.DiscountPercentage.Value.ToString("0.##")%
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                                        None
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-gray-600">@product.StockQuantity</td>
                            <td class="px-6 py-4">
                                @if (product.Status == ProductStatus.Active)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">@T["Admin.Status.Active"]</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">@product.Status</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-gray-600">@product.ImageCount</td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id"
                                       class="px-3 py-1.5 text-xs font-medium text-brand-600 border border-brand-300 rounded-lg hover:bg-brand-50 transition">@T["Action.Edit"]</a>
                                    <form asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" onclick="return confirm('@T["Admin.Products.DeleteConfirm"]');" class="px-3 py-1.5 text-xs font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition">@T["Action.Delete"]</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
