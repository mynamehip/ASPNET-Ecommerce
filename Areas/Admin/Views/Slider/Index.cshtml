@model SliderIndexViewModel

@{
    ViewData["Title"] = "Slider";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Slider</h1>
        <p class="text-sm text-gray-500 mt-1">Manage banner slides and regular homepage slides with service-level validation and visibility rules.</p>
    </div>
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="Slider" asp-action="CreateBanner"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 shadow-sm transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            New Banner
        </a>
        <a asp-area="Admin" asp-controller="Slider" asp-action="CreateSlide"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            New Slide
        </a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-emerald-800 bg-emerald-50 border border-emerald-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        @statusMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="flex items-center gap-2 p-4 mb-4 text-sm text-red-800 bg-red-50 border border-red-200 rounded-lg">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        @errorMessage
    </div>
}

<div class="space-y-8">
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900">Banner Slides</h2>
            <p class="text-sm text-gray-500 mt-1">Banner slides can omit background images and will fall back to the default storefront background later.</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4">Preview</th>
                        <th class="px-6 py-4">Content</th>
                        <th class="px-6 py-4">Buttons</th>
                        <th class="px-6 py-4">Order</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (Model.BannerItems.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-gray-400">No banner slides yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.BannerItems)
                        {
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrWhiteSpace(item.BackgroundImagePath))
                                    {
                                        <img src="@item.BackgroundImagePath" alt="Banner background" class="w-28 h-16 rounded-lg object-cover border border-gray-200" />
                                    }
                                    else
                                    {
                                        <div class="w-28 h-16 rounded-lg border border-dashed border-gray-300 bg-gray-50 flex items-center justify-center text-xs text-gray-400">
                                            Default background
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-semibold text-gray-900">@item.Title</div>
                                    <div class="text-xs text-gray-500 mt-1">@item.Content</div>
                                    <div class="text-xs text-gray-400 mt-1 line-clamp-2">@item.Description</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-xs text-gray-600 break-all">Primary: @(item.PrimaryButtonUrl ?? "-")</div>
                                    <div class="text-xs text-gray-400 break-all mt-1">Secondary: @(item.SecondaryButtonUrl ?? "-")</div>
                                </td>
                                <td class="px-6 py-4 text-gray-600">@item.DisplayOrder</td>
                                <td class="px-6 py-4">
                                    @if (item.IsActive)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Visible</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Hidden</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center gap-2">
                                        <a asp-area="Admin" asp-controller="Slider" asp-action="Edit" asp-route-id="@item.Id"
                                           class="px-3 py-1.5 text-xs font-medium text-brand-600 border border-brand-300 rounded-lg hover:bg-brand-50 transition">Edit</a>
                                        <form asp-area="Admin" asp-controller="Slider" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" onclick="return confirm('Delete this banner slide?');" class="px-3 py-1.5 text-xs font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900">Regular Slides</h2>
            <p class="text-sm text-gray-500 mt-1">Regular slides require a background image. Click URL is optional.</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4">Preview</th>
                        <th class="px-6 py-4">Click URL</th>
                        <th class="px-6 py-4">Order</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (Model.SlideItems.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-400">No regular slides yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.SlideItems)
                        {
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrWhiteSpace(item.BackgroundImagePath))
                                    {
                                        <img src="@item.BackgroundImagePath" alt="Slide background" class="w-28 h-16 rounded-lg object-cover border border-gray-200" />
                                    }
                                </td>
                                <td class="px-6 py-4 text-xs text-gray-600 break-all">@(string.IsNullOrWhiteSpace(item.ClickUrl) ? "-" : item.ClickUrl)</td>
                                <td class="px-6 py-4 text-gray-600">@item.DisplayOrder</td>
                                <td class="px-6 py-4">
                                    @if (item.IsActive)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Visible</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Hidden</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center gap-2">
                                        <a asp-area="Admin" asp-controller="Slider" asp-action="Edit" asp-route-id="@item.Id"
                                           class="px-3 py-1.5 text-xs font-medium text-brand-600 border border-brand-300 rounded-lg hover:bg-brand-50 transition">Edit</a>
                                        <form asp-area="Admin" asp-controller="Slider" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" onclick="return confirm('Delete this slide?');" class="px-3 py-1.5 text-xs font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
